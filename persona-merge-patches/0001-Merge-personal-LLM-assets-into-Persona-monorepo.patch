+    let step = 0;
+    let playing = false;
+    let timers = [];
+    const RECORD = new URLSearchParams(location.search).has("record");
+    const STEP_WAIT = RECORD ? 2000 : 1200;
+    const TYPE_MS = RECORD ? 24 : 18;
+
+    const $ = (s) => document.querySelector(s);
+    const agentsEl = $("#agents");
+    const messagesEl = $("#messages");
+    const templatesEl = $("#templates");
+    const captionEl = $("#caption");
+    const progressEl = $("#progress");
+
+    function renderAgents(active) {
+      agentsEl.innerHTML = Object.entries(AGENTS).map(([id, a]) =>
+        `<div class="agent ${active === id ? "active" : ""}" style="--c:${a.color}"><span class="emoji">${a.emoji}</span><div><strong>${a.name}</strong><span>${a.role}</span></div></div>`
+      ).join("");
+    }
+
+    function renderTemplates() {
+      templatesEl.innerHTML = TEMPLATES.map((t) =>
+        `<div class="template" data-id="${t.id}"><div class="e">${t.emoji}</div><strong>${t.title}</strong><small>${t.desc}</small></div>`
+      ).join("");
+    }
+
+    function setCaption(text) { captionEl.textContent = text; }
+    function setProgress() {
+      progressEl.textContent = playing ? `Step ${step + 1} / ${SCRIPT.length}` : (step >= SCRIPT.length ? "Done" : "Ready");
+    }
+
+    function highlightTemplate(id) {
+      document.querySelectorAll(".template").forEach((el) => el.classList.toggle("highlight", el.dataset.id === id));
+    }
+
+    function clickTemplate() {
+      highlightTemplate("side-project");
+      setMode("project");
+    }
+
+    function setMode(mode) {
+      document.querySelectorAll(".mode-tab").forEach((t) => t.classList.toggle("active", t.dataset.mode === mode));
+    }
+
+    function addUserMsg(text) {
+      $("#welcome")?.remove();
+      const div = document.createElement("div");
+      div.className = "msg user";
+      div.innerHTML = `<div class="bubble">${text}</div>`;
+      messagesEl.appendChild(div);
+      messagesEl.scrollTop = messagesEl.scrollHeight;
+    }
+
+    function streamAgent(id, phase, fullText) {
+      return new Promise((resolve) => {
+        renderAgents(id);
+        const a = AGENTS[id];
+        const phaseLabel = phase === "plan" ? " · Plan" : phase === "summary" ? " · Summary" : "";
+        const div = document.createElement("div");
+        div.className = "msg agent";
+        div.style.setProperty("--c", a.color);
+        div.innerHTML = `<div class="meta">${a.emoji} <strong>${a.name}</strong> · ${a.role}${phaseLabel}</div><div class="bubble typing"></div>`;
+        messagesEl.appendChild(div);
+        const bubble = div.querySelector(".bubble");
+        let i = 0;
+        const plain = fullText.replace(/\*\*/g, "");
+        const tick = () => {
+          if (i < plain.length) {
+            i += 3;
+            bubble.innerHTML = formatMd(fullText.slice(0, Math.min(i * 1.2, fullText.length)));
+            messagesEl.scrollTop = messagesEl.scrollHeight;
+            timers.push(setTimeout(tick, TYPE_MS));
+          } else {
+            bubble.classList.remove("typing");
+            bubble.innerHTML = formatMd(fullText);
+            resolve();
+          }
+        };
+        tick();
+      });
+    }
+
+    function formatMd(t) {
+      return t
+        .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
+        .replace(/\n/g, "<br>")
+        .replace(/- /g, "• ");
+    }
+
+    function showBoard() {
+      $("#chat-view").classList.add("hidden");
+      $("#board-view").classList.add("visible");
+      setMode("board");
+      document.querySelector('[data-mode="board"]').classList.add("active");
+      renderBoard();
+    }
+
+    function renderBoard() {
+      const cols = { backlog: "Backlog", in_progress: "In Progress", review: "Review", done: "Done" };
+      $("#kanban").innerHTML = Object.entries(cols).map(([key, label]) => {
+        const tasks = BOARD[key].map((t) => {
+          const a = AGENTS[t.assignee];
+          return `<div class="task" id="${t.id}" style="--c:${a.color}">${t.title}<br><small>${a.emoji} ${a.name}</small></div>`;
+        }).join("");
+        return `<div class="col"><h3>${label}</h3>${tasks}</div>`;
+      }).join("");
+    }
+
+    function moveTask() {
+      const task = document.getElementById("t1");
+      if (!task) return;
+      task.classList.add("moving");
+      timers.push(setTimeout(() => {
+        BOARD.backlog = BOARD.backlog.filter((t) => t.id !== "t1");
+        BOARD.in_progress.push({ title: "Pick product name & domain", assignee: "sketch", id: "t1" });
+        renderBoard();
+      }, 600));
+    }
+
+    function showCta() {
+      $("#cta").classList.add("visible");
+      setCaption("Download Persona — free, private, works offline on Windows");
+    }
+
+    function clearTimers() { timers.forEach(clearTimeout); timers = []; }
+
+    async function runStep() {
+      if (step >= SCRIPT.length) {
+        playing = false;
+        $("#play-btn").hidden = false;
+        $("#restart-btn").hidden = false;
+        setProgress();
+        document.body.dataset.demoComplete = "1";
+        return;
+      }
+      const s = SCRIPT[step];
+      setCaption(s.t);
+      setProgress();
+      if (s.fn) await Promise.resolve(s.fn());
+      step++;
+      if (playing) timers.push(setTimeout(runStep, s.wait || STEP_WAIT));
+      else setProgress();
+    }
+
+    function reset() {
+      clearTimers();
+      step = 0;
+      playing = false;
+      BOARD.in_progress = [];
+      BOARD.backlog = [
+        { title: "Pick product name & domain", assignee: "sketch", id: "t1" },
+        { title: "Competitive research", assignee: "nova", id: "t2" },
+      ];
+      messagesEl.innerHTML = `<div id="welcome"><h2 style="font-size:1rem;margin-bottom:0.35rem;">What would you like to work on?</h2><p style="color:var(--text-muted);font-size:0.85rem;margin-bottom:0.5rem;">Pick a template — Captain and the crew plan it with you.</p><div class="templates" id="templates"></div></div>`;
+      renderTemplates();
+      $("#chat-view").classList.remove("hidden");
+      $("#board-view").classList.remove("visible");
+      $("#cta").classList.remove("visible");
+      setMode("project");
+      renderAgents(null);
+      $("#play-btn").hidden = false;
+      $("#restart-btn").hidden = true;
+      setCaption("Click Play demo to watch Persona plan a side project in ~60 seconds");
+      setProgress();
+    }
+
+    $("#play-btn").addEventListener("click", () => {
+      if (playing) return;
+      if (step >= SCRIPT.length) reset();
+      playing = true;
+      $("#play-btn").hidden = true;
+      runStep();
+    });
+
+    $("#restart-btn").addEventListener("click", () => { reset(); playing = true; $("#play-btn").hidden = true; runStep(); });
+
+    renderAgents(null);
+    renderTemplates();
+    setProgress();
+
+    if (new URLSearchParams(location.search).has("play") || RECORD) {
+      const start = () => $("#play-btn")?.click();
+      if (RECORD) {
+        $("#record-intro").classList.add("visible");
+        timers.push(setTimeout(() => {
+          $("#record-intro").classList.remove("visible");
+          start();
+        }, 2800));
+      } else {
+        timers.push(setTimeout(start, 400));
+      }
+    }
+  </script>
+</body>
+</html>
