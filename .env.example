# Persona provider: ollama | openai
PERSONA_PROVIDER=ollama

# Ollama (default — runs models locally)
PERSONA_OLLAMA_BASE_URL=http://localhost:11434
PERSONA_OLLAMA_MODEL=llama3.2

# OpenAI-compatible API
PERSONA_OPENAI_BASE_URL=https://api.openai.com/v1
PERSONA_OPENAI_API_KEY=
PERSONA_OPENAI_MODEL=gpt-4o-mini

# Agent behavior
PERSONA_MAX_TOOL_ROUNDS=15
PERSONA_WORKSPACE=.

# Web app
PERSONA_WEB_HOST=127.0.0.1
PERSONA_WEB_PORT=8765
