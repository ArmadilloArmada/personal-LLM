# LLM provider: ollama | openai
PERSONAL_LLM_PROVIDER=ollama

# Ollama (default — runs models locally)
PERSONAL_LLM_OLLAMA_BASE_URL=http://localhost:11434
PERSONAL_LLM_OLLAMA_MODEL=llama3.2

# OpenAI-compatible API (OpenAI, Groq, Together, local vLLM, etc.)
PERSONAL_LLM_OPENAI_BASE_URL=https://api.openai.com/v1
PERSONAL_LLM_OPENAI_API_KEY=
PERSONAL_LLM_OPENAI_MODEL=gpt-4o-mini

# Agent behavior
PERSONAL_LLM_MAX_TOOL_ROUNDS=15
PERSONAL_LLM_WORKSPACE=.
